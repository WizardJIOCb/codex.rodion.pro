{
  "name": "@cmc/server",
  "version": "0.1.0",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "start": "node --no-warnings=ExperimentalWarning dist/index.js",
    "seed:user": "tsx src/cli.ts seed:user",
    "agents:create": "tsx src/cli.ts agents:create",
    "agents:rotate-token": "tsx src/cli.ts agents:rotate-token"
  },
  "dependencies": {
    "@cmc/protocol": "workspace:*",
    "@fastify/cookie": "^11.0.2",
    "@fastify/static": "^8.2.0",
    "@fastify/websocket": "^11.0.2",
    "bcryptjs": "^3.0.2",
    "fastify": "^5.3.3",
    "nanoid": "^5.1.5",
    "zod": "^3.25.28"
  },
  "devDependencies": {
    "@types/node": "^22.15.21",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
