{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Codex Agent",
  "version": "0.1.0",
  "identifier": "pro.rodion.codex.agent",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Codex Agent",
        "width": 960,
        "height": 760,
        "minWidth": 520,
        "minHeight": 620,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.ico"
    ],
    "category": "DeveloperTool",
    "shortDescription": "Tray manager for codex.rodion.pro agent",
    "longDescription": "Native tray manager for codex.rodion.pro sync agent, VS Code bridge, and local chat synchronization."
  }
}
